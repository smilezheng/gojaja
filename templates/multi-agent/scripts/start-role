#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
project_root="$(cd "$repo_root/.." && pwd)"

usage() {
  cat <<'USAGE'
Usage:
  .multi-agent/scripts/start-role [--target codex|claude|cursor|generic] <role>

Prints the ready-to-use startup prompt for an existing role.
This is the trigger mechanism for starting a role agent in Codex, Claude Code, Cursor, or another file-capable agent.
USAGE
}

validate_role_name() {
  local role="$1"
  if [[ ! "$role" =~ ^[A-Za-z0-9_-]+$ ]]; then
    echo "Invalid role: $role" >&2
    echo "Use a simple role id such as PM, TechLead, backend, qa-automation, or ux_research." >&2
    exit 2
  fi
}

target="generic"

if [ "${1:-}" = "--target" ]; then
  if [ "$#" -lt 3 ]; then
    usage
    exit 2
  fi
  target="$2"
  shift 2
fi

if [ "$#" -ne 1 ]; then
  usage
  exit 2
fi

role="$1"
validate_role_name "$role"

case "$target" in
  codex|claude|cursor|generic) ;;
  *)
    echo "Unknown target: $target" >&2
    echo "Use codex, claude, cursor, or generic." >&2
    exit 2
    ;;
esac

role_file="$repo_root/roles/$role.md"
inbox_file="$repo_root/comms/inbox/$role.md"
cursor_file="$repo_root/comms/cursors/$role.cursor"
worklog_file="$repo_root/worklog/$role.md"

if [ ! -f "$role_file" ] || [ ! -f "$inbox_file" ] || [ ! -f "$cursor_file" ] || [ ! -f "$worklog_file" ]; then
  echo "Role is missing or incomplete: $role" >&2
  echo "Expected:" >&2
  echo "  roles/$role.md" >&2
  echo "  comms/inbox/$role.md" >&2
  echo "  comms/cursors/$role.cursor" >&2
  echo "  worklog/$role.md" >&2
  exit 1
fi

case "$target" in
  codex)
    target_name="Codex"
    runtime_line='Use $multi-agent-runtime for this role window.'
    ;;
  claude)
    target_name="Claude Code"
    runtime_line='Follow the runtime loop in this prompt directly. Codex skills are not required.'
    ;;
  cursor)
    target_name="Cursor"
    runtime_line='Follow the runtime loop in this prompt directly. Codex skills are not required.'
    ;;
  generic)
    target_name="agent"
    runtime_line='Follow the runtime loop in this prompt directly. Codex skills are not required.'
    ;;
esac

cat <<PROMPT
Copy this prompt into the $target_name window for this role:

--- BEGIN ROLE PROMPT ---
$runtime_line

You are the $role agent for this multi-agent project.

Project root:
$project_root

Trigger condition:
You are now operating under the project-local, agent-agnostic multi-agent coordination protocol.

Before doing any work, read these files:
- .multi-agent/protocol/PROTOCOL.md
- .multi-agent/roles/$role.md
- .multi-agent/state/project_state.md
- .multi-agent/state/task_board.md
- .multi-agent/state/decisions.md
- .multi-agent/state/risks.md
- .multi-agent/comms/inbox/$role.md
- .multi-agent/worklog/$role.md

Then run:

.multi-agent/scripts/agentctl sync $role
.multi-agent/scripts/agentctl mark-online $role "started turn"

Follow .multi-agent/roles/$role.md as your role contract. Stay inside your assigned responsibilities and writable scope. Do not edit other agents' worklogs or state owned by another role unless the task board or a project decision explicitly assigns that work to you.

Use these runtime coordination commands:
- .multi-agent/scripts/agentctl roles
- .multi-agent/scripts/agentctl status
- .multi-agent/scripts/agentctl sync $role
- .multi-agent/scripts/agentctl ack $role
- .multi-agent/scripts/agentctl digest $role
- .multi-agent/scripts/agentctl inbox $role
- .multi-agent/scripts/agentctl report <from-role> <to-role> "<message>"
- .multi-agent/scripts/agentctl worklog $role "<message>"
- .multi-agent/scripts/agentctl new-rfc <number> <slug> "<title>"
- .multi-agent/scripts/agentctl rfc-status <rfc-id-or-dir>
- .multi-agent/scripts/agentctl vote-rfc $role <rfc-id-or-dir> approve|reject|abstain "<reason>"

Do not create, remove, or rename roles. Role management is a user-side setup action.

At the start of each turn, sync your role file, shared state, inbox, and worklog, then run .multi-agent/scripts/agentctl sync $role. After you process the sync output, run .multi-agent/scripts/agentctl ack $role. After meaningful progress, write your worklog and report to the project-defined coordination roles. If a blocking cross-role product or architecture decision is needed, create or comment on an RFC instead of guessing.

Before ending each substantive turn, run a final coordination pass: write worklog/report if needed, then run .multi-agent/scripts/agentctl sync $role again if the turn took meaningful time or changed coordination state, and ack only after processing the output.

Before final response, call this blocking lifecycle hook:

.multi-agent/hooks/turn-end $role 10

It performs a final sync, waits 10 minutes when there are no unread events, then runs the second sync/idle-check before returning. If it reports attention_required, process the new events before ending. If it reports offline, this role may end the turn.
--- END ROLE PROMPT ---
PROMPT
