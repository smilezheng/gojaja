#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
lock_script="$repo_root/scripts/with_lock.sh"

usage() {
  cat <<'USAGE'
Usage:
  .multi-agent/scripts/agentctl roles
  .multi-agent/scripts/agentctl status
  .multi-agent/scripts/agentctl sync <role>
  .multi-agent/scripts/agentctl ack <role>
  .multi-agent/scripts/agentctl digest <role>
  .multi-agent/scripts/agentctl hook turn-end <role> [idle-minutes] [--no-wait]
  .multi-agent/scripts/agentctl idle-check <role>
  .multi-agent/scripts/agentctl mark-online <role> [note]
  .multi-agent/scripts/agentctl mark-offline <role> [note]
  .multi-agent/scripts/agentctl inbox <role>
  .multi-agent/scripts/agentctl notify <from-role> <to-role> <message>
  .multi-agent/scripts/agentctl report <from-role> <to-role> <message>
  .multi-agent/scripts/agentctl worklog <role> <message>
  .multi-agent/scripts/agentctl new-rfc <number> <slug> <title>
  .multi-agent/scripts/agentctl rfc-status <rfc-id-or-dir>
  .multi-agent/scripts/agentctl vote-rfc <role> <rfc-id-or-dir> approve|reject|abstain <reason>

Roles are discovered dynamically from roles/<role>.md.
USAGE
}

role_file() {
  printf '%s/roles/%s.md' "$repo_root" "$1"
}

role_inbox() {
  printf '%s/comms/inbox/%s.md' "$repo_root" "$1"
}

role_worklog() {
  printf '%s/worklog/%s.md' "$repo_root" "$1"
}

role_cursor() {
  printf '%s/comms/cursors/%s.cursor' "$repo_root" "$1"
}

role_status() {
  printf '%s/comms/status/%s.md' "$repo_root" "$1"
}

events_log() {
  printf '%s/comms/events.log' "$repo_root"
}

events_seq() {
  printf '%s/comms/events.seq' "$repo_root"
}

validate_role_name() {
  local role="$1"
  if [[ ! "$role" =~ ^[A-Za-z0-9_-]+$ ]]; then
    echo "Invalid role: $role" >&2
    echo "Use a simple role id such as PM, TechLead, backend, qa-automation, or ux_research." >&2
    exit 2
  fi
}

list_roles() {
  local file
  local name
  find "$repo_root/roles" -maxdepth 1 -type f -name '*.md' ! -name 'README.md' -print | sort | while IFS= read -r file; do
    name="$(basename "$file" .md)"
    printf '%s\n' "$name"
  done
}

known_roles_inline() {
  list_roles | tr '\n' ' ' | sed 's/[[:space:]]*$//'
}

is_role() {
  local role="$1"
  validate_role_name "$role"
  [ -f "$(role_file "$role")" ]
}

require_role() {
  local role="$1"
  if ! is_role "$role"; then
    echo "Unknown role: $role" >&2
    echo "Known roles: $(known_roles_inline)" >&2
    echo "Roles are created by the project user with .multi-agent/scripts/create-role." >&2
    exit 2
  fi
}

timestamp() {
  date '+%Y-%m-%d %H:%M:%S %z'
}

last_event_id() {
  if [ -s "$(events_log)" ]; then
    tail -n 1 "$(events_log)" | awk -F '\t' '{print $1}'
  else
    printf '0\n'
  fi
}

role_cursor_value() {
  local role="$1"
  local cursor_file
  cursor_file="$(role_cursor "$role")"
  if [ -s "$cursor_file" ]; then
    sed -n '1p' "$cursor_file"
  else
    printf '0\n'
  fi
}

resolve_rfc_dir() {
  local ref="$1"
  local candidate
  if [ -d "$repo_root/rfcs/$ref" ]; then
    printf '%s/rfcs/%s\n' "$repo_root" "$ref"
    return 0
  fi
  if [ -d "$ref" ]; then
    (cd "$ref" && pwd)
    return 0
  fi
  candidate="$(find "$repo_root/rfcs" -maxdepth 1 -type d -name "$ref*" -print | sort | sed -n '1p')"
  if [ -n "$candidate" ]; then
    printf '%s\n' "$candidate"
    return 0
  fi
  echo "Unknown RFC: $ref" >&2
  exit 2
}

print_unread_events() {
  local role="$1"
  local cursor="$2"
  local log_file
  log_file="$(events_log)"
  if [ ! -s "$log_file" ]; then
    echo "No events recorded."
    return 0
  fi
  awk -F '\t' -v cursor="$cursor" -v role="$role" '
    $1 > cursor && ($5 == role || $5 == "*" || $4 == role) {
      printf "- #%s [%s] %s %s -> %s %s\n  %s\n", $1, $2, $3, $4, $5, $6, $7
    }
  ' "$log_file"
}

unread_event_count() {
  local role="$1"
  local cursor="$2"
  local log_file
  log_file="$(events_log)"
  if [ ! -s "$log_file" ]; then
    printf '0\n'
    return 0
  fi
  awk -F '\t' -v cursor="$cursor" -v role="$role" '
    $1 > cursor && ($5 == role || $5 == "*" || $4 == role) {count++}
    END {print count + 0}
  ' "$log_file"
}

write_role_status() {
  local role="$1"
  local state="$2"
  local note="$3"
  local latest
  latest="$(last_event_id)"
  "$lock_script" bash -c '
    file="$1"
    role="$2"
    state="$3"
    note="$4"
    ts="$5"
    latest="$6"
    mkdir -p "$(dirname "$file")"
    {
      printf "# %s Status\n\n" "$role"
      printf "State: %s\n" "$state"
      printf "Updated: %s\n" "$ts"
      printf "LatestEvent: %s\n" "$latest"
      printf "Note: %s\n" "$note"
    } > "$file"
  ' _ "$(role_status "$role")" "$role" "$state" "$note" "$(timestamp)" "$latest"
}

cmd_status() {
  echo "Roles:"
  list_roles | sed 's/^/- /'
  echo
  echo "Role statuses:"
  find "$repo_root/comms/status" -maxdepth 1 -type f -name '*.md' -print 2>/dev/null | sort | while IFS= read -r file; do
    printf -- "- %s: " "$(basename "$file" .md)"
    awk -F ': ' '/^State:/{state=$2} /^Updated:/{updated=$2} END {printf "%s (%s)\n", state, updated}' "$file"
  done
  echo
  echo "Project state:"
  sed -n '1,120p' "$repo_root/state/project_state.md"
  echo
  echo "Task board:"
  sed -n '1,160p' "$repo_root/state/task_board.md"
  echo
  echo "Open risks:"
  sed -n '1,160p' "$repo_root/state/risks.md"
}

cmd_sync() {
  local role="$1"
  local cursor
  require_role "$role"
  cursor="$(role_cursor_value "$role")"

  echo "Sync for role: $role"
  echo "Cursor: $cursor"
  echo "Latest event: $(last_event_id)"
  echo
  echo "Unread events:"
  print_unread_events "$role" "$cursor"
  echo
  echo "Inbox:"
  sed -n '1,200p' "$(role_inbox "$role")"
  echo
  echo "Task board:"
  sed -n '1,220p' "$repo_root/state/task_board.md"
  echo
  echo "Open RFCs and role actions:"
  find "$repo_root/rfcs" -maxdepth 2 -name proposal.md -print | sort | while IFS= read -r proposal; do
    dir="$(dirname "$proposal")"
    status="$(awk '/^## Status/{getline; while ($0=="") getline; print; exit}' "$proposal")"
    owner="$(awk '/^## Owner/{getline; while ($0=="") getline; print; exit}' "$proposal")"
    [ -n "$status" ] || status="Unknown"
    [ "$status" = "Accepted" ] || [ "$status" = "Rejected" ] || {
      printf -- "- %s status=%s owner=%s\n" "$(basename "$dir")" "$status" "$owner"
      [ -f "$dir/comments/$role.md" ] && printf "  comment: %s\n" "$dir/comments/$role.md"
      [ -d "$dir/votes" ] && [ ! -f "$dir/votes/$role.md" ] && printf "  vote pending: %s\n" "$dir/votes/$role.md"
    }
  done
  echo
  echo "Run '.multi-agent/scripts/agentctl ack $role' after you have processed this sync output."
}

cmd_ack() {
  local role="$1"
  local latest
  require_role "$role"
  latest="$(last_event_id)"
  "$lock_script" bash -c '
    mkdir -p "$(dirname "$1")"
    printf "%s\n" "$2" > "$1"
  ' _ "$(role_cursor "$role")" "$latest"
  echo "Acked $role through event #$latest"
}

cmd_mark_online() {
  local role="$1"
  local note="${2:-active}"
  require_role "$role"
  write_role_status "$role" "online" "$note"
  echo "Marked $role online."
}

cmd_mark_offline() {
  local role="$1"
  local note="${2:-offline}"
  require_role "$role"
  write_role_status "$role" "offline" "$note"
  echo "Marked $role offline."
}

cmd_hook_turn_end() {
  local role="$1"
  local idle_minutes="${2:-10}"
  local wait_mode="${3:---wait}"
  local cursor
  local unread
  local sleep_seconds
  require_role "$role"
  case "$wait_mode" in
    --wait|--no-wait) ;;
    *) echo "Unknown turn-end mode: $wait_mode" >&2; exit 2 ;;
  esac

  echo "Turn-end hook for role: $role"
  echo
  cmd_sync "$role"
  cursor="$(role_cursor_value "$role")"
  unread="$(unread_event_count "$role" "$cursor")"

  if [ "$unread" -gt 0 ]; then
    write_role_status "$role" "attention_required" "$unread unread event(s); process sync output before ending turn"
    echo
    echo "Hook result: attention_required"
    echo "There are $unread unread event(s). Process them, then run:"
    echo "  .multi-agent/scripts/agentctl ack $role"
    echo "Do not mark this role idle/offline yet."
    return 1
  fi

  cmd_ack "$role"
  write_role_status "$role" "idle_pending" "No unread events at turn end. Recheck after ${idle_minutes} minute(s)."
  echo
  echo "Hook result: idle_pending"
  if [ "$wait_mode" = "--no-wait" ]; then
    echo "No-wait mode. Schedule this delayed recheck command after ${idle_minutes} minute(s):"
    echo "  .multi-agent/scripts/agentctl idle-check $role"
    return 0
  fi

  sleep_seconds=$((idle_minutes * 60))
  echo "Waiting ${idle_minutes} minute(s), then running idle-check in this process."
  if [ "$sleep_seconds" -gt 0 ]; then
    sleep "$sleep_seconds"
  fi
  echo
  cmd_idle_check "$role"
}

cmd_idle_check() {
  local role="$1"
  local cursor
  local unread
  require_role "$role"
  cursor="$(role_cursor_value "$role")"
  unread="$(unread_event_count "$role" "$cursor")"

  echo "Idle check for role: $role"
  echo "Cursor: $cursor"
  echo "Latest event: $(last_event_id)"

  if [ "$unread" -gt 0 ]; then
    write_role_status "$role" "attention_required" "$unread unread event(s) arrived during idle wait"
    echo "Hook result: attention_required"
    echo "There are $unread unread event(s). Run:"
    echo "  .multi-agent/scripts/agentctl sync $role"
    return 1
  fi

  cmd_ack "$role"
  write_role_status "$role" "offline" "No unread events after idle recheck."
  echo "Hook result: offline"
  echo "$role is now marked offline in $(role_status "$role")."
}

cmd_digest() {
  local role="$1"
  require_role "$role"
  echo "Digest for role: $role"
  echo
  cmd_sync "$role"
  echo
  echo "Recent worklog entries:"
  find "$repo_root/worklog" -maxdepth 1 -type f -name '*.md' -print | sort | while IFS= read -r file; do
    echo
    echo "## $(basename "$file")"
    tail -n 20 "$file"
  done
  echo
  echo "Risks:"
  sed -n '1,200p' "$repo_root/state/risks.md"
}

cmd_inbox() {
  local role="$1"
  require_role "$role"
  if [ ! -f "$(role_inbox "$role")" ]; then
    echo "Inbox does not exist for role: $role" >&2
    echo "Ask the project user to create or repair the role with .multi-agent/scripts/create-role." >&2
    exit 1
  fi
  sed -n '1,240p' "$(role_inbox "$role")"
}

cmd_report() {
  local from_role="$1"
  local to_role="$2"
  local message="$3"
  require_role "$from_role"
  require_role "$to_role"

  "$lock_script" bash -c '
    file="$1"
    from_role="$2"
    to_role="$3"
    ts="$4"
    message="$5"
    events_log="$6"
    events_seq="$7"
    mkdir -p "$(dirname "$events_log")"
    seq=0
    [ -s "$events_seq" ] && seq="$(cat "$events_seq")"
    seq=$((seq + 1))
    printf "%s\n" "$seq" > "$events_seq"
    {
      printf "\n## %s - %s -> %s\n\n" "$ts" "$from_role" "$to_role"
      printf "%s\n" "$message"
    } >> "$file"
    printf "%s\t%s\tREPORT\t%s\t%s\t-\t%s\n" "$seq" "$ts" "$from_role" "$to_role" "$message" >> "$events_log"
  ' _ "$(role_inbox "$to_role")" "$from_role" "$to_role" "$(timestamp)" "$message" "$(events_log)" "$(events_seq)"
}

cmd_worklog() {
  local role="$1"
  local message="$2"
  require_role "$role"

  "$lock_script" bash -c '
    file="$1"
    role="$2"
    ts="$3"
    message="$4"
    events_log="$5"
    events_seq="$6"
    mkdir -p "$(dirname "$events_log")"
    seq=0
    [ -s "$events_seq" ] && seq="$(cat "$events_seq")"
    seq=$((seq + 1))
    printf "%s\n" "$seq" > "$events_seq"
    {
      printf "\n## %s - %s\n\n" "$ts" "$role"
      printf "%s\n" "$message"
    } >> "$file"
    printf "%s\t%s\tWORKLOG\t%s\t*\t-\t%s\n" "$seq" "$ts" "$role" "$message" >> "$events_log"
  ' _ "$(role_worklog "$role")" "$role" "$(timestamp)" "$message" "$(events_log)" "$(events_seq)"
}

cmd_new_rfc() {
  local number="$1"
  local slug="$2"
  local title="$3"
  local roles_snapshot
  local rfc_id
  local dir

  roles_snapshot="$(list_roles)"
  rfc_id="$(printf 'RFC-%04d' "$number")"
  dir="$repo_root/rfcs/$rfc_id-$slug"

  if [ -e "$dir" ]; then
    echo "RFC already exists: $dir" >&2
    exit 1
  fi

  "$lock_script" bash -c '
    dir="$1"
    rfc_id="$2"
    title="$3"
    ts="$7"
    events_log="$8"
    events_seq="$9"
    mkdir -p "$dir/comments"
    mkdir -p "$dir/votes"
    sed "s/RFC-XXXX/$rfc_id/g; s/Title/$title/g" "$4" > "$dir/proposal.md"
    sed "s/RFC-XXXX/$rfc_id/g" "$5" > "$dir/decision.md"
    printf "%s\n" "$6" | while IFS= read -r role; do
      [ -n "$role" ] || continue
      comment_file="$role"
      {
        printf "# %s Feedback for %s\n\n" "$role" "$rfc_id"
        printf "## Impact\n\nTBD\n\n"
        printf "## Preferred Option\n\nTBD\n\n"
        printf "## Concerns\n\nTBD\n\n"
        printf "## Required Changes\n\nTBD\n"
      } > "$dir/comments/$comment_file.md"
    done
    mkdir -p "$(dirname "$events_log")"
    seq=0
    [ -s "$events_seq" ] && seq="$(cat "$events_seq")"
    seq=$((seq + 1))
    printf "%s\n" "$seq" > "$events_seq"
    printf "%s\t%s\tRFC_CREATED\tSYSTEM\t*\t%s\t%s\n" "$seq" "$ts" "$rfc_id" "$title" >> "$events_log"
  ' _ "$dir" "$rfc_id" "$title" "$repo_root/rfcs/TEMPLATE.md" "$repo_root/rfcs/DECISION_TEMPLATE.md" "$roles_snapshot" "$(timestamp)" "$(events_log)" "$(events_seq)"

  echo "$dir"
}

cmd_rfc_status() {
  local ref="$1"
  local dir
  dir="$(resolve_rfc_dir "$ref")"
  echo "RFC: $(basename "$dir")"
  echo
  sed -n '1,120p' "$dir/proposal.md"
  echo
  echo "Comments:"
  find "$dir/comments" -maxdepth 1 -type f -name '*.md' -print | sort | while IFS= read -r file; do
    printf -- "- %s\n" "$(basename "$file")"
  done
  echo
  echo "Votes:"
  if [ -d "$dir/votes" ]; then
    find "$dir/votes" -maxdepth 1 -type f -name '*.md' -print | sort | while IFS= read -r file; do
      printf -- "- %s: " "$(basename "$file" .md)"
      awk '/^## Vote/{getline; while ($0=="") getline; print; exit}' "$file"
    done
  else
    echo "No votes directory."
  fi
  echo
  echo "Decision:"
  sed -n '1,160p' "$dir/decision.md"
}

cmd_vote_rfc() {
  local role="$1"
  local ref="$2"
  local vote="$3"
  local reason="$4"
  local dir
  local rfc_name
  require_role "$role"
  case "$vote" in
    approve|reject|abstain) ;;
    *) echo "Vote must be approve, reject, or abstain." >&2; exit 2 ;;
  esac
  dir="$(resolve_rfc_dir "$ref")"
  rfc_name="$(basename "$dir")"
  "$lock_script" bash -c '
    role="$1"
    vote="$2"
    reason="$3"
    file="$4"
    ts="$5"
    events_log="$6"
    events_seq="$7"
    rfc_name="$8"
    mkdir -p "$(dirname "$file")"
    {
      printf "# %s Vote for %s\n\n" "$role" "$rfc_name"
      printf "## Vote\n\n%s\n\n" "$vote"
      printf "## Reason\n\n%s\n\n" "$reason"
      printf "## Time\n\n%s\n" "$ts"
    } > "$file"
    mkdir -p "$(dirname "$events_log")"
    seq=0
    [ -s "$events_seq" ] && seq="$(cat "$events_seq")"
    seq=$((seq + 1))
    printf "%s\n" "$seq" > "$events_seq"
    printf "%s\t%s\tRFC_VOTE\t%s\t*\t%s\t%s: %s\n" "$seq" "$ts" "$role" "$rfc_name" "$vote" "$reason" >> "$events_log"
  ' _ "$role" "$vote" "$reason" "$dir/votes/$role.md" "$(timestamp)" "$(events_log)" "$(events_seq)" "$rfc_name"
  echo "Recorded $vote vote for $role on $rfc_name"
}

main() {
  if [ "$#" -lt 1 ]; then
    usage
    exit 2
  fi

  case "$1" in
    roles)
      [ "$#" -eq 1 ] || { usage; exit 2; }
      list_roles
      ;;
    status)
      [ "$#" -eq 1 ] || { usage; exit 2; }
      cmd_status
      ;;
    sync)
      [ "$#" -eq 2 ] || { usage; exit 2; }
      cmd_sync "$2"
      ;;
    ack)
      [ "$#" -eq 2 ] || { usage; exit 2; }
      cmd_ack "$2"
      ;;
    digest)
      [ "$#" -eq 2 ] || { usage; exit 2; }
      cmd_digest "$2"
      ;;
    hook)
      [ "$#" -ge 3 ] || { usage; exit 2; }
      case "$2" in
        turn-end)
          cmd_hook_turn_end "$3" "${4:-10}" "${5:---wait}"
          ;;
        *)
          usage
          exit 2
          ;;
      esac
      ;;
    idle-check)
      [ "$#" -eq 2 ] || { usage; exit 2; }
      cmd_idle_check "$2"
      ;;
    mark-online)
      [ "$#" -ge 2 ] || { usage; exit 2; }
      cmd_mark_online "$2" "${3:-active}"
      ;;
    mark-offline)
      [ "$#" -ge 2 ] || { usage; exit 2; }
      cmd_mark_offline "$2" "${3:-offline}"
      ;;
    inbox)
      [ "$#" -eq 2 ] || { usage; exit 2; }
      cmd_inbox "$2"
      ;;
    notify)
      [ "$#" -ge 4 ] || { usage; exit 2; }
      shift
      cmd_report "$1" "$2" "$3"
      ;;
    report)
      [ "$#" -ge 4 ] || { usage; exit 2; }
      shift
      cmd_report "$1" "$2" "$3"
      ;;
    worklog)
      [ "$#" -ge 3 ] || { usage; exit 2; }
      shift
      cmd_worklog "$1" "$2"
      ;;
    new-rfc)
      [ "$#" -ge 4 ] || { usage; exit 2; }
      shift
      cmd_new_rfc "$1" "$2" "$3"
      ;;
    rfc-status)
      [ "$#" -eq 2 ] || { usage; exit 2; }
      cmd_rfc_status "$2"
      ;;
    vote-rfc)
      [ "$#" -ge 5 ] || { usage; exit 2; }
      shift
      cmd_vote_rfc "$1" "$2" "$3" "$4"
      ;;
    *)
      usage
      exit 2
      ;;
  esac
}

main "$@"
