{
  "name": "multi-agent-coordination",
  "version": "2.0.0-alpha.0",
  "description": "Agent-agnostic file-system coordination layer for multi-LLM-agent collaboration.",
  "bin": {
    "agentctl": "./bin/agentctl",
    "multi-agent": "./bin/agentctl",
