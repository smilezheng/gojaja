  "description": "Agent-agnostic file-system coordination layer for multi-LLM-agent collaboration (Codex, Claude Code, Cursor, ...).",
  "keywords": [
    "multi-agent",
    "agent-coordination",
    "agentctl",
    "llm",
    "llm-agents",
    "codex",
    "claude-code",
    "cursor",
    "rfc",
    "task-board",
    "cli"
  ],
  "homepage": "https://github.com/smilezheng/multi-agent-coordination#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smilezheng/multi-agent-coordination.git"
  },
  "bugs": {
    "url": "https://github.com/smilezheng/multi-agent-coordination/issues"
  },
  "author": {
    "name": "smilezheng",
    "email": "smile_zheng@163.com"
  },
  "license": "MIT",
  "bin": {
    "agentctl": "bin/agentctl",
    "multi-agent": "bin/agentctl",
    "multi-agent-coordination": "bin/agentctl"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
